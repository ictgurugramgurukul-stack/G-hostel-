# Nothing here is required to get started - the app works out of the box
# with sensible defaults (a local SQLite file + an auto-generated app
# secret). Copy this file to .env only if you want to override something.

# Where to store the local database file (default: backend/gurukul.db)
# DB_PATH=gurukul.db

# Signs login sessions. If left blank, one is generated automatically on
# first run and saved back into this file - you don't need to set it.
# SECRET_KEY=

# How long a login stays valid, in seconds (default: 30 days)
# TOKEN_LIFETIME_SECONDS=2592000

# Comma-separated list of origins allowed to call this API (your frontend URL(s))
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000,http://127.0.0.1:8000
